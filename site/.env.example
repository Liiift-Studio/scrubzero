# scrubzero.org paid tier (Phase 1) — env vars. Set these in Vercel (Project →
# Settings → Environment Variables). Everything degrades gracefully if unset:
# no auth vars = no sign-in; no Stripe = no billing; the free tools keep working.

# ── Auth.js (free, self-hosted) ─────────────────────────────────────────────
# Generate: `openssl rand -base64 32`  (or: npx auth secret)
AUTH_SECRET=

# Configure AT LEAST ONE OAuth provider. Google is best for non-technical users.
# Google:  create an OAuth client at https://console.cloud.google.com/apis/credentials
#          Authorized redirect URI: https://scrubzero.org/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# GitHub (optional/alternative): https://github.com/settings/developers
#          Authorization callback URL: https://scrubzero.org/api/auth/callback/github
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=

# ── Stripe (billing) ────────────────────────────────────────────────────────
# Secret key: https://dashboard.stripe.com/apikeys  (use a test key first: sk_test_…)
STRIPE_SECRET_KEY=
# Webhook signing secret: create a webhook to https://scrubzero.org/api/billing/webhook
#   listening for `checkout.session.completed`, then copy its signing secret (whsec_…)
STRIPE_WEBHOOK_SECRET=
# The credit-pack Price ID (price_…). The Price MUST have metadata `credits=<N>`
# (e.g. credits=1000). Claude can create this for you once the Stripe connector is
# authenticated (/mcp → "claude.ai Stripe"), or make it in the Stripe dashboard.
STRIPE_PRICE_ID=

# ── Hosted AI detection (Phase 1 — NOT yet BAA-covered) ─────────────────────
# Server Anthropic key used for signed-in credit-based scans (no BYOK needed).
# Do NOT market a HIPAA/legal tier until a BAA + zero-data-retention is signed.
ANTHROPIC_API_KEY=
